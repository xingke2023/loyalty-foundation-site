<!-- Hero Section with Slideshow -->
<section id="home" class="relative flex items-start justify-center pt-20" style="min-height: 100vh;">
    <!-- Background Slideshow -->
    <div id="heroSlideshow" class="absolute inset-0 mt-20">
        <div class="hero-slide active bg-cover bg-center bg-no-repeat"
             style="background-image: url('<%- url_for('/images/old-site-images/bdd35b_5f5ff62020374f1db7402794a18a77d0~mv2.jpg') %>'); background-position: top center;"></div>
        <div class="hero-slide bg-cover bg-center bg-no-repeat"
             style="background-image: url('<%- url_for('/images/old-site-images/bdd35b_47df2a13b744453e913cd6efdbe6d7cb~mv2.jpg') %>'); background-position: center center;"></div>
        <div class="hero-slide bg-cover bg-center bg-no-repeat"
             style="background-image: url('<%- url_for('/images/old-site-images/bdd35b_07e559de8d6d4793a587f3669eccb6dc~mv2.jpg') %>'); background-position: center center;"></div>
        <div class="hero-slide bg-cover bg-center bg-no-repeat"
             style="background-image: url('<%- url_for('/images/old-site-images/bdd35b_7cfd4f8434e14ce9acc3b619050460b8~mv2.jpg') %>'); background-position: center center;"></div>
    </div>
    <div class="absolute inset-0 mt-20 bg-black opacity-20"></div>
    <div class="relative z-10 text-center text-white px-4 mt-48">
        <h1 class="text-4xl md:text-6xl font-bold mb-8 font-merriweather tracking-wider leading-tight">Heal Together, Stronger After</h1>
        <!-- Slide Caption -->
        <div id="slideCaption" class="text-lg md:text-2xl mb-6 font-medium opacity-90"></div>
        <a href="#mission"
            class="bg-primary hover:bg-secondary text-white font-bold py-3 px-8 rounded-full transition duration-300 shadow-lg transform hover:scale-105">Our
            Mission</a>
    </div>
</section>

<style>
.hero-slide {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    transition: opacity 1.5s ease-in-out;
}

.hero-slide.active {
    opacity: 1;
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const slides = document.querySelectorAll('.hero-slide');
    const captionElement = document.getElementById('slideCaption');
    let currentSlide = 0;

    // Captions for each slide
    const captions = [
        '愛•無窮 Love • Infinite',
        '南區夜繽紛慈善攤位',
        '送暖贈送福袋給獨居老人',
        '派飯送暖給露宿者'
    ];

    function updateCaption() {
        if (captionElement) {
            captionElement.textContent = captions[currentSlide];
        }
    }

    function nextSlide() {
        slides[currentSlide].classList.remove('active');
        currentSlide = (currentSlide + 1) % slides.length;
        slides[currentSlide].classList.add('active');
        updateCaption();
    }

    // Initialize first caption
    updateCaption();

    // Change slide every 5 seconds
    setInterval(nextSlide, 5000);
});
</script>

