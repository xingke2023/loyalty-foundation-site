<article class="pt-32 pb-20 bg-white">
    <div class="container mx-auto px-6">
        <% if (!index) { %>
        <div class="max-w-4xl mx-auto">
            <h1 class="text-4xl font-bold text-gray-800 mb-6"><%= post.title %></h1>
            <div class="text-gray-600 leading-relaxed">
                <%- post.content %>
            </div>
        </div>
        <% } else { %>
        <div class="mb-8">
            <h2 class="text-2xl font-bold mb-4">
                <a href="<%- url_for(post.path) %>" class="text-gray-800 hover:text-primary"><%= post.title %></a>
            </h2>
            <div class="text-gray-600">
                <%- post.excerpt || post.content %>
            </div>
            <% if (post.excerpt) { %>
            <a href="<%- url_for(post.path) %>" class="text-primary font-medium hover:text-secondary mt-4 inline-block">Read More →</a>
            <% } %>
        </div>
        <% } %>
    </div>
</article>
